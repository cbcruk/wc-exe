{
  "name": "wc-exe",
  "version": "0.1.0",
  "description": "WebContainer Executor - Headless build tool for frontend projects",
  "type": "module",
  "bin": {
    "wc-exe": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/runner/dist"
  ],
  "scripts": {
    "build": "pnpm run build:runner && tsup",
    "build:runner": "cd src/runner && pnpm run build",
    "build:cli": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "cd src/runner && pnpm install"
  },
  "keywords": [
    "webcontainer",
    "build",
    "vite",
    "webpack",
    "security",
    "headless"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@webcontainer/api": "^1.3.1",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "hono": "^4.11.3",
    "http-proxy": "^1.18.1",
    "ora": "^8.1.0",
    "puppeteer-core": "^23.5.0"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^0.2.83",
    "@anthropic-ai/sdk": "^0.26.0",
    "@eslint/js": "^9.39.2",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^22.7.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.51.0",
    "vitest": "^2.1.2"
  }
}
